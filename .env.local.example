## ComfyUI base URL
## - Local: http://127.0.0.1:8188
## - RunPod: https://<podid>-8188.proxy.runpod.net
## - Tailscale VPN: http://100.x.y.z:8188 (recommended for different Wi-Fi)
COMFYUI_BASE_URL=http://127.0.0.1:8188

## 워크플로 템플릿: 루트 z image_v4.json 단 하나 (lib/comfy/buildWorkflow.js 의 WORKFLOW_TEMPLATE_FILE)

## RunPod Serverless — v2 /run + /status, 아래 curl 과 같은 호출 방식
## - RUNPOD_INPUT_PROMPT_ONLY=1 → RunPod 로 보내는 input 은 prompt 위주(아래 curl 과 동일하게 쓰려면 1).
## - RUNPOD_INPUT_PROMPT_ONLY 비움/0 → 같은 엔드포인트에 input.prompt + input.workflow (템플릿은 위 json 하나뿐).
##
## curl -X POST https://api.runpod.ai/v2/9zmno1r8i4sed4/run \
##   -H 'Content-Type: application/json' \
##   -H 'Authorization: Bearer YOUR_API_KEY' \
##   -d '{"input":{"prompt":"Your prompt"}}'
RUNPOD_API_KEY=
RUNPOD_ENDPOINT_ID=9zmno1r8i4sed4
## 워커가 Missing workflow / Comfy API JSON 을 요구하면 0 (기본). prompt 만 받는 핸들러일 때만 1
RUNPOD_INPUT_PROMPT_ONLY=0
## 워커에 Text Multiline(172) 없을 때만 1 — 커스텀 노드 경로 맞춘 뒤에는 비우는 것을 권장
# RUNPOD_STRIP_TEXT_MULTILINE=1
## 모델 not in [] 시: 워커에서 /runpod-volume/models 등과 실제 ComfyUI models 심볼릭 링크 점검
## → docs/runpod-serverless-worker-paths.md

## RunPod 응답 이미지: 배경 제거 → PNG 알파 (lib/runpod/applyAlphaPipeline.js, sharp)
## 배경 모드: 기본 light — 연한 배경 + 진한 캐릭터(대비). white | green | dark(=light 호환)
# CHROMA_BACKGROUND=light
## 연배경 키 색 RGB (프롬프트 #F3F4F8 근처와 맞출 것). 기본 244,245,250
# CHROMA_LIGHT_RGB=244,245,250
## light 모드: 하단 회색 그림자 띠 알파 제거 (기본 켜짐). 끄려면 CHROMA_STRIP_FLOOR_SHADOW=0
# CHROMA_STRIP_FLOOR_SHADOW=1
## 위 스트립 적용 세로 구간 비율 (하단부터, 기본 0.28)
# CHROMA_FLOOR_SHADOW_BOTTOM=0.28
## 키잉 후 PNG 하단을 비율만큼 잘라냄 (0=끔). 프롬프트로 하단 여백을 넓혔을 때 그림자 띠만 도려내기 — 예: 0.08
# CHROMA_CROP_BOTTOM=0
## white 모드: 직선 알파를 화이트 위에 올린 RGB (기본 켜짐). 끄려면 CHROMA_WHITE_MATTE=0
# CHROMA_WHITE_MATTE=1
## 고정 프롬프트: light / white / green (lib/comfy/buildWorkflow.js)
## 기본 켜짐. 끄려면 RUNPOD_IMAGE_ALPHA=0
# RUNPOD_IMAGE_ALPHA=1
## L∞ 거리 + G 우세 휴리스틱(기본 켜짐). 끄려면 CHROMA_USE_HEURISTIC=0
# CHROMA_USE_HEURISTIC=1
## 0~255 (기본 40). 예전 WHITE_BG_TOLERANCE 도 읽음
# CHROMA_TOLERANCE=40
## 페더 폭 (기본 14). 예전 WHITE_BG_FEATHER 도 읽음
# CHROMA_FEATHER=14
## L∞ + g-max(r,b) 보조 거리 블렌드 (기본 켜짐). 끄려면 CHROMA_USE_CHROMA_DIST=0
# CHROMA_USE_CHROMA_DIST=1
## 알파 경계 스무스스텝 (기본 켜짐). 끄려면 CHROMA_SMOOTHSTEP=0
# CHROMA_SMOOTHSTEP=1
## 1차 디스필 0~1 (기본 0.62). 0이면 끔
# CHROMA_DESPILL=0.62
## 밝은 피사체(흰 털) 구멍 방지 (기본 켜짐). 끄려면 CHROMA_HIGHLIGHT_PROTECT=0
# CHROMA_HIGHLIGHT_PROTECT=1
## 알파 3×3 클로징 — 작은 구멍 메우기 (기본 켜짐). 끄려면 CHROMA_MORPH_CLOSE=0
# CHROMA_MORPH_CLOSE=1
## 바닥 그림자(어두운 초록) 추가 키잉 (기본 켜짐). 끄려면 CHROMA_KEY_FLOOR_SHADOW=0
# CHROMA_KEY_FLOOR_SHADOW=1
## 알파만 블러( RGB 유지 ) 시그마 0~8 (기본 1.15). 0이면 끔
# CHROMA_EDGE_BLUR_SIGMA=1.15
## 반투명 가장자리 2차 디스필 0~1 (기본 0.42). 0이면 끔
# CHROMA_EDGE_DESPILL=0.42
