## ComfyUI base URL
## - Local: http://127.0.0.1:8188
## - RunPod: https://<podid>-8188.proxy.runpod.net
## - Tailscale VPN: http://100.x.y.z:8188 (recommended for different Wi-Fi)
COMFYUI_BASE_URL=http://127.0.0.1:8188

## 워크플로 템플릿: 루트 genmo0404.json 단 하나 (lib/comfy/buildWorkflow.js 의 WORKFLOW_TEMPLATE_FILE)

## RunPod Serverless — v2 /run + /status, 아래 curl 과 같은 호출 방식
## - RUNPOD_INPUT_PROMPT_ONLY=1 → RunPod 로 보내는 input 은 prompt 위주(아래 curl 과 동일하게 쓰려면 1).
## - RUNPOD_INPUT_PROMPT_ONLY 비움/0 → 같은 엔드포인트에 input.prompt + input.workflow (템플릿은 위 json 하나뿐).
##
## curl -X POST https://api.runpod.ai/v2/9zmno1r8i4sed4/run \
##   -H 'Content-Type: application/json' \
##   -H 'Authorization: Bearer YOUR_API_KEY' \
##   -d '{"input":{"prompt":"Your prompt"}}'
RUNPOD_API_KEY=
RUNPOD_ENDPOINT_ID=9zmno1r8i4sed4
## 워커가 Missing workflow / Comfy API JSON 을 요구하면 0 (기본). prompt 만 받는 핸들러일 때만 1
RUNPOD_INPUT_PROMPT_ONLY=0
## 워커에 Text Multiline(172) 없을 때만 1 — 커스텀 노드 경로 맞춘 뒤에는 비우는 것을 권장
# RUNPOD_STRIP_TEXT_MULTILINE=1
## 모델 not in [] 시: 워커에서 /runpod-volume/models 등과 실제 ComfyUI models 심볼릭 링크 점검
## → docs/runpod-serverless-worker-paths.md

## RunPod 응답 이미지는 배경 제거 없이 원본(화이트 배경)을 그대로 사용합니다.
## 대신 하단 그림자 띠를 숨기기 위해 결과 이미지 하단을 크롭합니다.
## 하단 크롭 비율 (기본 0.08 = 하단 8% 제거). 0으로 두면 크롭 비활성화.
# RUNPOD_CROP_BOTTOM=0.08
